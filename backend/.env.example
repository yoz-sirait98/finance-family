APP_NAME="Family Finance"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yjsfinance.web.id
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

# Increase for production (12 is fine, 13-14 for higher security at CPU cost)
BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=errorlog
LOG_LEVEL=warning

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
DB_CONNECTION=pgsql
# Supabase connection credentials
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=CHANGE_THIS_SUPABASE_PASSWORD
DB_SSLMODE=require

# ── Session / Cache / Queue (Database driver for Render free tier) ───────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# For cross-domain, session domain is ignored as we use Bearer Tokens
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Broadcasting ─────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── Filesystem ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Sanctum ──────────────────────────────────────────────────────────────────
# Informational only, since we use Bearer tokens instead of cookies
SANCTUM_STATEFUL_DOMAINS=yjsfinance.web.id
# Token expiration in minutes (null = never). Recommend 1440 (24h) for production.
SANCTUM_TOKEN_EXPIRATION=1440

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yjsfinance.my.id
CORS_ALLOWED_ORIGINS=https://yjsfinance.my.id

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.yourmailprovider.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=CHANGE_THIS_MAIL_PASSWORD
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"
